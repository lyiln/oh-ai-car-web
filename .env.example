POSTGRES_DB=oh_ai_car
POSTGRES_USER=oh_ai_car
POSTGRES_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-at-least-32-random-bytes
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-before-first-start
VITE_AMAP_KEY=your-amap-web-js-key
VITE_PLATFORM_ENABLED=true
AMAP_SECURITY_JS_CODE=your-amap-security-js-code
WEB_PORT=8080
COOKIE_SECURE=false
PLATFORM_PUBLIC_ORIGIN=http://localhost:8080
# 仅在还需要允许额外的前端 Origin 时填写，多个值用英文逗号分隔。
PLATFORM_ALLOWED_ORIGINS=
