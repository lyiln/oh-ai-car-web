# 环境变量说明
#
# 团队开发（私有仓库）：
#   1. git pull && npm install
#   2. npm run setup:env -- <neon-password>
#   3. npm run dev:backend / npm run dev:frontend
#
# 密码向项目负责人索取，或在 Neon 控制台查看（需被邀请加入项目）。
# 本地覆盖：编辑 .env（git 忽略）；共享主机/账号见 .env.development。

DATABASE_HOST=host
DATABASE_PORT=5432
DATABASE_NAME=oh_ai_car
DATABASE_USER=user
NEON_PASSWORD=replace-with-neon-password
SESSION_SECRET=replace-with-at-least-32-random-bytes
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-before-first-start
VITE_AMAP_KEY=your-amap-web-js-key
VITE_PLATFORM_ENABLED=true
AMAP_SECURITY_JS_CODE=your-amap-security-js-code
WEB_PORT=8080
COOKIE_SECURE=false
PLATFORM_PUBLIC_ORIGIN=http://127.0.0.1:5173
PLATFORM_ALLOWED_ORIGINS=
