# 环境变量说明
#
# 团队开发（私有仓库）：
#   1. git pull && npm install
#   2. npm run setup:env -- <neon-password>
#   3. npm run dev:backend / npm run dev:frontend
#
# 本文件只能包含占位符；`.env` 是本机运行配置且被 Git 忽略。

DATABASE_HOST=your-postgres-host
DATABASE_PORT=5432
DATABASE_NAME=oh_ai_car
DATABASE_USER=your-postgres-user
NEON_PASSWORD=replace-with-your-password
SESSION_SECRET=generated-by-setup-env
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-unique-password
# 管理员邮箱登录依赖 SMTP；这些值只在后端运行环境中使用，绝不交给浏览器。
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.invalid
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=replace-with-your-smtp-password
SMTP_FROM=PatrolPlate <no-reply@example.com>
VITE_AMAP_KEY=your-amap-web-js-key
VITE_MAP_DEFAULT_ZOOM=18
# 定位失败时的回退中心，格式：经度,纬度（示例为北京交通大学附近）
VITE_MAP_DEFAULT_CENTER=116.339,39.949
VITE_PLATFORM_ENABLED=true
AMAP_SECURITY_JS_CODE=your-amap-security-js-code
WEB_PORT=8080
COOKIE_SECURE=false
# Default binding stays local. Only set HOST=0.0.0.0 for an approved LAN edge
# deployment protected by firewall rules, HTTPS, and the configured Origins.
# HOST=0.0.0.0
# Jetson plate vision (see docs/integration/yolo-plate-recognition.md)
# YOLO_REPO_PATH=YOLOv5/oh-ai-car-YOLOv5
# YOLO_DEVICE=0
# YOLO_CAR_WEIGHTS=YOLOv5/oh-ai-car-YOLOv5/weights/car_bdd100k_mini_v1_best.pt
# YOLO_PLATE_WEIGHTS=YOLOv5/oh-ai-car-YOLOv5/weights/best_plate_detector_v2.pt
# YOLO_OCR_MIN_SCORE=0.75
# YOLO_PIPELINE_MODE=two_stage
# PLATE_VIDEO_SOURCE=0
# PLATE_DETECTOR_MODE=auto
# Console plate scan also needs: npm run dev:plate-api  (:8010)
# EVIDENCE_PUBLIC_BASE_URL=http://10.82.66.179:8089/evidence  # 仅当 EVIDENCE_UPLOAD_TO_PLATFORM=0 时使用
# Host-side evidence storage (Jetson uploads JPEG here for Web admin review)
# EVIDENCE_STORAGE_DIR=./data/evidence
# Edge: EVIDENCE_UPLOAD_TO_PLATFORM=1 (default) posts JPEGs to POST /device/v1/evidence
# Jetson/edge agents on LAN need an explicitly approved HOST=0.0.0.0 deployment.
PLATFORM_PUBLIC_ORIGIN=http://127.0.0.1:5173
PLATFORM_ALLOWED_ORIGINS=
# 本地控制网关必须验证平台租约；启动 gateway 时使用此地址。
PLATFORM_API_URL=http://127.0.0.1:8788
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
