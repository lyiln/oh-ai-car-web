{
  "name": "@oh-ai-car-web/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:integration": "tsc --noEmit -p tsconfig.integration.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/websocket": "^11.0.0",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.14",
    "testcontainers": "^12.0.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "ws": "^8.18.2"
  }
}
