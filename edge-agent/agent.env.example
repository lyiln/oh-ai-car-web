# 复制为同目录 agent.env 后按现场改（agent.env 勿提交）
#   cp agent.env.example agent.env

# 跑后端的那台电脑局域网 IP（换热点后只改这一行）
PLATFORM_API_URL=http://172.20.10.14:8788

# 浏览器 Console 签发的整串 id.secret（每辆车各自一条）
DEVICE_CREDENTIAL=替换成你的凭据

NAV_MODE=nav2
MAP_VERSION=yahboomcar
NAV_ASSUME_BRINGUP=true

# 本目录在容器内的路径（一般不用改）
EDGE_AGENT_DIR=/root/oh-ai-car-web/edge-agent

# Nav2 action（与 ros2 action list 一致，建议带前导 /）
NAV2_ACTION=/navigate_to_pose
NAV2_WAIT_SERVER_SEC=45

# 可选：有工作空间时取消注释并改成你的 setup.bash
# ROS_SETUP=/opt/ros/foxy/setup.bash
# WS_SETUP=/root/yahboomcar_ros2_ws/yahboomcar_ws/install/setup.bash
